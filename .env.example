# Nahua Kukui — Environment Variables
# Copy this file to .env and fill in the values

# Plausible Analytics (optional — add after launch)
# PUBLIC_PLAUSIBLE_DOMAIN=nahuakukui.com

# Formspree form ID for contact form
# PUBLIC_FORMSPREE_ID=your_form_id

# Calendly URL for discovery call booking
# PUBLIC_CALENDLY_URL=https://calendly.com/your-url
