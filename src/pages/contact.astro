---
import Base from "../layouts/Base.astro";
---

<Base
  title="Contact"
  description="Get in touch with Na Hua Kukui for sessions, trainings, or questions about Lomi Lomi bodywork."
  canonicalPath="/contact"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "LocalBusiness",
      "name": "Na Hua Kukui",
      "description": "Lomi Lomi bodywork and training in the lineage of Kahu Abraham Kawaii.",
      "url": "https://nahuakukui.com",
      "email": "contact@nahuakukui.com",
      "telephone": "+1-808-283-3797"
    })} />
  </Fragment>

  {/* Page Hero */}
  <section class="bg-bg-dark pt-32 pb-20 md:pt-40 md:pb-24">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <h1 class="font-serif text-4xl md:text-5xl font-semibold text-gold mb-6">Contact</h1>
      <p class="text-text-inverse/70 text-lg leading-relaxed">
        For session inquiries, training information, or questions about the work, reach out below.
      </p>
    </div>
  </section>

  {/* Contact Options */}
  <section class="bg-bg-light py-24 md:py-32">
    <div class="max-w-3xl mx-auto px-6">
      <div class="grid md:grid-cols-2 gap-12 md:gap-16">

        {/* Email */}
        <div>
          <h2 class="font-serif text-2xl font-semibold text-accent mb-6">Email</h2>
          <div class="flex flex-col gap-4">
            <a
              href="mailto:nahuakukui@protonmail.com"
              class="text-gold font-medium hover:underline text-lg"
            >
              nahuakukui@protonmail.com
            </a>
            <a
              href="mailto:contact@nahuakukui.com"
              class="text-gold font-medium hover:underline text-lg"
            >
              contact@nahuakukui.com
            </a>
          </div>
        </div>

        {/* Phone */}
        <div>
          <h2 class="font-serif text-2xl font-semibold text-accent mb-6">Phone</h2>
          <a
            href="tel:+18082833797"
            class="text-gold font-medium hover:underline text-lg"
          >
            (808) 283-3797
          </a>
        </div>

      </div>

      {/* Contact Form */}
      <div class="mt-16 pt-16 border-t border-accent/10">
        <h2 class="font-serif text-2xl font-semibold text-accent mb-6">Send a Message</h2>
        <form
          action="https://formspree.io/f/YOUR_FORM_ID"
          method="POST"
          class="flex flex-col gap-5 max-w-xl"
        >
          <div>
            <label for="name" class="block text-sm font-medium text-text mb-1">Name</label>
            <input
              type="text"
              id="name"
              name="name"
              required
              class="w-full px-4 py-3 border border-accent/20 rounded-sm bg-white text-text focus:outline-none focus:ring-2 focus:ring-gold/50 focus:border-gold transition-colors"
            />
          </div>
          <div>
            <label for="email" class="block text-sm font-medium text-text mb-1">Email</label>
            <input
              type="email"
              id="email"
              name="email"
              required
              class="w-full px-4 py-3 border border-accent/20 rounded-sm bg-white text-text focus:outline-none focus:ring-2 focus:ring-gold/50 focus:border-gold transition-colors"
            />
          </div>
          <div>
            <label for="message" class="block text-sm font-medium text-text mb-1">Message</label>
            <textarea
              id="message"
              name="message"
              rows="5"
              required
              class="w-full px-4 py-3 border border-accent/20 rounded-sm bg-white text-text focus:outline-none focus:ring-2 focus:ring-gold/50 focus:border-gold transition-colors resize-y"
            ></textarea>
          </div>
          <button type="submit" class="btn-primary text-center cursor-pointer self-start">
            Send message
          </button>
        </form>
      </div>
    </div>
  </section>

  {/* Closing */}
  <section class="bg-bg-dark py-16">
    <div class="max-w-md mx-auto px-6 text-center">
      <div class="w-8 h-[1px] bg-gold/40 mx-auto mb-6" aria-hidden="true"></div>
      <p class="font-serif text-sm text-text-inverse/50 italic">
        Na Hua Kukui &mdash; The Seeds of Light
      </p>
    </div>
  </section>
</Base>
