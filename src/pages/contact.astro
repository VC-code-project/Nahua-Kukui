---
import Base from "../layouts/Base.astro";
---

<Base
  title="Contact"
  description="Reach out for session inquiries, bookings, or questions about therapeutic and sacred bodywork with Na Hua Kukui."
  canonicalPath="/contact"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "LocalBusiness",
      "name": "Na Hua Kukui",
      "description": "Therapeutic and sacred bodywork rooted in Hawaiian lineage.",
      "url": "https://nahuakukui.com",
      "email": "hello@nahuakukui.com"
    })} />
  </Fragment>

  {/* Page Hero */}
  <section class="bg-bg-dark pt-32 pb-20 md:pt-40 md:pb-24">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <h1 class="font-serif text-4xl md:text-5xl font-semibold text-gold mb-6">Reach Out</h1>
      <p class="text-text-inverse/70 text-lg leading-relaxed">
        For session inquiries, bookings, or questions about the work, send a message. Responses within a few days.
      </p>
    </div>
  </section>

  {/* Contact Options */}
  <section class="bg-bg-light py-24 md:py-32">
    <div class="max-w-4xl mx-auto px-6">
      <div class="grid md:grid-cols-2 gap-12 md:gap-16">

        {/* Left: Email + Form */}
        <div>
          <h2 class="font-serif text-2xl font-semibold text-accent mb-6">Send a Message</h2>

          {/* Direct email option */}
          <div class="mb-10">
            <p class="text-text/80 mb-3">Prefer email? Write directly:</p>
            <a
              href="mailto:hello@nahuakukui.com"
              class="text-gold font-medium hover:underline text-lg"
            >
              hello@nahuakukui.com
            </a>
          </div>

          {/* Simple contact form */}
          <form
            action="https://formspree.io/f/YOUR_FORM_ID"
            method="POST"
            class="flex flex-col gap-5"
          >
            <div>
              <label for="name" class="block text-sm font-medium text-text mb-1">Name</label>
              <input
                type="text"
                id="name"
                name="name"
                required
                class="w-full px-4 py-3 border border-accent/20 rounded-sm bg-white text-text focus:outline-none focus:ring-2 focus:ring-gold/50 focus:border-gold transition-colors"
              />
            </div>
            <div>
              <label for="email" class="block text-sm font-medium text-text mb-1">Email</label>
              <input
                type="email"
                id="email"
                name="email"
                required
                class="w-full px-4 py-3 border border-accent/20 rounded-sm bg-white text-text focus:outline-none focus:ring-2 focus:ring-gold/50 focus:border-gold transition-colors"
              />
            </div>
            <div>
              <label for="message" class="block text-sm font-medium text-text mb-1">Message</label>
              <textarea
                id="message"
                name="message"
                rows="5"
                required
                class="w-full px-4 py-3 border border-accent/20 rounded-sm bg-white text-text focus:outline-none focus:ring-2 focus:ring-gold/50 focus:border-gold transition-colors resize-y"
              ></textarea>
            </div>
            <button type="submit" class="btn-primary text-center cursor-pointer self-start">
              Send message
            </button>
          </form>
        </div>

        {/* Right: Calendly */}
        <div id="booking">
          <h2 class="font-serif text-2xl font-semibold text-accent mb-6">Book a Discovery Call</h2>
          <p class="text-text/80 mb-6">
            Not sure where to start? Schedule a free 15-minute call to talk through what you're looking for.
          </p>

          {/* Calendly placeholder — replace YOUR_CALENDLY_URL */}
          <div class="bg-white border border-accent/10 rounded-sm p-8 min-h-[400px] flex items-center justify-center">
            <div class="text-center text-muted">
              <p class="text-sm italic mb-4">Calendly booking widget will appear here</p>
              <p class="text-xs">
                Replace <code class="bg-accent/10 px-1 py-0.5 rounded text-accent">YOUR_CALENDLY_URL</code> in the code with the Calendly link
              </p>
            </div>
          </div>
          <!--
            To enable Calendly, uncomment and replace YOUR_CALENDLY_URL:
            <div class="calendly-inline-widget" data-url="https://calendly.com/YOUR_CALENDLY_URL" style="min-width:320px;height:630px;"></div>
            <script type="text/javascript" src="https://assets.calendly.com/assets/external/widget.js" async></script>
          -->
        </div>

      </div>
    </div>
  </section>

  {/* Closing */}
  <section class="bg-bg-dark py-16">
    <div class="max-w-md mx-auto px-6 text-center">
      <div class="w-8 h-[1px] bg-gold/40 mx-auto mb-6" aria-hidden="true"></div>
      <p class="font-serif text-sm text-text-inverse/50 italic">
        Na Hua Kukui &mdash; The Seeds of Light
      </p>
    </div>
  </section>
</Base>
