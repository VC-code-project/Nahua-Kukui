---
const year = new Date().getFullYear();
---

<footer class="bg-bg-dark text-text-inverse/70 py-16">
  <div class="max-w-6xl mx-auto px-6">
    <div class="flex flex-col md:flex-row justify-between items-start gap-10">
      {/* Brand */}
      <div class="max-w-xs">
        <a href="/" class="font-serif text-xl font-semibold text-gold tracking-wide">
          Na Hua Kukui
        </a>
        <p class="mt-2 text-sm italic text-text-inverse/50">The Seeds of Light</p>
      </div>

      {/* Nav */}
      <nav aria-label="Footer navigation" class="flex gap-8 text-sm tracking-wide uppercase">
        <a href="/about" class="hover:text-gold transition-colors">About</a>
        <a href="/offerings" class="hover:text-gold transition-colors">Offerings</a>
        <a href="/contact" class="hover:text-gold transition-colors">Contact</a>
      </nav>

      {/* Contact */}
      <div class="text-sm">
        <a href="mailto:hello@nahuakukui.com" class="hover:text-gold transition-colors">
          hello@nahuakukui.com
        </a>
      </div>
    </div>

    <div class="mt-12 pt-6 border-t border-white/10 flex flex-col md:flex-row justify-between items-center gap-4 text-xs text-text-inverse/40">
      <p>&copy; {year} Na Hua Kukui. All rights reserved.</p>
      <a href="/privacy" class="hover:text-text-inverse/60 transition-colors">Privacy</a>
    </div>
  </div>
</footer>
