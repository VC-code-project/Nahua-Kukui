---
const currentPath = Astro.url.pathname;
const navItems = [
  { label: "About", href: "/about" },
  { label: "Offerings", href: "/offerings" },
  { label: "Contact", href: "/contact" },
];
---

<header class="fixed top-0 left-0 right-0 z-50 bg-bg-dark/95 backdrop-blur-sm">
  <nav class="max-w-6xl mx-auto flex items-center justify-between px-6 py-4" aria-label="Main navigation">
    <a href="/" class="font-serif text-xl font-semibold text-gold tracking-wide">
      Na Hua Kukui
    </a>

    {/* Desktop nav */}
    <div class="hidden md:flex items-center gap-8">
      {navItems.map((item) => (
        <a
          href={item.href}
          class:list={[
            "text-sm tracking-wide uppercase transition-colors",
            currentPath === item.href || currentPath === item.href + "/"
              ? "text-gold"
              : "text-text-inverse/80 hover:text-gold",
          ]}
        >
          {item.label}
        </a>
      ))}
      <a href="/contact" class="btn-primary text-sm !py-3 !px-6">Book a session</a>
    </div>

    {/* Mobile menu button */}
    <button
      id="mobile-menu-btn"
      class="md:hidden text-text-inverse p-2"
      aria-expanded="false"
      aria-controls="mobile-menu"
      aria-label="Open menu"
    >
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path id="menu-icon" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </nav>

  {/* Mobile menu */}
  <div
    id="mobile-menu"
    class="md:hidden hidden bg-bg-dark border-t border-white/10"
    role="menu"
  >
    <div class="flex flex-col px-6 py-6 gap-4">
      {navItems.map((item) => (
        <a
          href={item.href}
          class:list={[
            "text-sm tracking-wide uppercase py-2",
            currentPath === item.href || currentPath === item.href + "/"
              ? "text-gold"
              : "text-text-inverse/80",
          ]}
          role="menuitem"
        >
          {item.label}
        </a>
      ))}
      <a href="/contact" class="btn-primary text-sm text-center mt-2">Book a session</a>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById("mobile-menu-btn");
  const menu = document.getElementById("mobile-menu");
  const icon = document.getElementById("menu-icon");

  btn?.addEventListener("click", () => {
    const expanded = btn.getAttribute("aria-expanded") === "true";
    btn.setAttribute("aria-expanded", String(!expanded));
    btn.setAttribute("aria-label", expanded ? "Open menu" : "Close menu");
    menu?.classList.toggle("hidden");
    if (icon) {
      icon.setAttribute(
        "d",
        expanded
          ? "M4 6h16M4 12h16M4 18h16"
          : "M6 18L18 6M6 6l12 12"
      );
    }
  });
</script>
